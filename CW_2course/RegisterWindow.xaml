<Window x:Class="CW_2course.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CW_2course"
        mc:Ignorable="d"
        Title="RegisterWindow" Height="640" Width="440">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#4F46E5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="#4F46E5" BorderThickness="1.5" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FFFFFF" CornerRadius="20" Margin="20" Padding="25">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,25">
                <TextBlock Text="📝" FontSize="32" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Реєстрація" FontSize="26" FontWeight="Black" Foreground="#1E293B" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Логін" Foreground="#64748B" FontSize="13" Margin="5,0,0,6" FontWeight="SemiBold"/>
                <Border BorderBrush="#CBD5E1" BorderThickness="1.5" CornerRadius="12" Height="45" Background="#F8FAFC">
                    <TextBox x:Name="RegLoginTextBox" BorderThickness="0" Background="Transparent" 
                             VerticalContentAlignment="Center" Padding="12,0,12,0" FontSize="14" Foreground="#1E293B"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Пароль" Foreground="#64748B" FontSize="13" Margin="5,0,0,6" FontWeight="SemiBold"/>
                <Border BorderBrush="#CBD5E1" BorderThickness="1.5" CornerRadius="12" Height="45" Background="#F8FAFC">
                    <PasswordBox x:Name="RegPasswordBox" BorderThickness="0" Background="Transparent" 
                                 VerticalContentAlignment="Center" Padding="12,0,12,0" FontSize="14" Foreground="#1E293B"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,25">
                <TextBlock Text="Підтвердіть пароль" Foreground="#64748B" FontSize="13" Margin="5,0,0,6" FontWeight="SemiBold"/>
                <Border BorderBrush="#CBD5E1" BorderThickness="1.5" CornerRadius="12" Height="45" Background="#F8FAFC">
                    <PasswordBox x:Name="ConfirmPasswordBox" BorderThickness="0" Background="Transparent" 
                                 VerticalContentAlignment="Center" Padding="12,0,12,0" FontSize="14" Foreground="#1E293B"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Row="4" VerticalAlignment="Bottom" Margin="0,15,0,0">
                <Button Content="ПРОДОВЖИТИ" Style="{StaticResource PrimaryButtonStyle}" Click="RegisterConfirm_Click"/>

                <Button Content="Назад до входу" Style="{StaticResource SecondaryButtonStyle}" Margin="0,10,0,0" Click="BackToLogin_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
