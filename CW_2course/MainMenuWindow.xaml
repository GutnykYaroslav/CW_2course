<Window x:Class="CW_2course.MainMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CW_2course"
        mc:Ignorable="d"
        Title="MainMenuWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📋 Мої Списки Завдань" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <ListBox Grid.Row="1" x:Name="ListsListBox" MouseDoubleClick="ListsListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="10">
                        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" Foreground="#333333"/>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Margin="0,15,0,0">
            <TextBox x:Name="NewListTitleInput" Height="35" VerticalContentAlignment="Center" Margin="0,0,0,10" Tag="Введіть назву нового списку..."/>
            <UniformGrid Columns="3" Height="40">
                <Button Content="➕ Створити" Click="CreateList_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold" Margin="0,0,-105,0"/>
                <Button Content="❌ Видалити" Click="DeleteList_Click" Background="#F44336" Foreground="White" FontWeight="Bold" Margin="105,0,-255,0"/>
               
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
