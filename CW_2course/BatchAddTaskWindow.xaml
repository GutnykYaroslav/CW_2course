<Window x:Class="CW_2course.BatchAddTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CW_2course"
        mc:Ignorable="d"
        Title="BatchAddTaskWindow" Height="500" Width="800">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Назва завдання:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox Grid.Row="1" x:Name="TitleInput" Height="25" Margin="0,0,0,10" Padding="2"/>

        <TextBlock Grid.Row="2" Text="Опис завдання:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox Grid.Row="3" x:Name="DescInput" Height="50" Margin="0,0,0,10" TextWrapping="Wrap" Padding="2"/>

        <Grid Grid.Row="4" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Пріоритет:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="PriorityInput" SelectedIndex="0" Padding="5">
                    <ComboBoxItem Content="Низький"/>
                    <ComboBoxItem Content="Середній"/>
                    <ComboBoxItem Content="Високий"/>
                    <ComboBoxItem Content="Критичний"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Складність:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox x:Name="DifficultyInput" SelectedIndex="0" Padding="5">
                    <ComboBoxItem Content="Легко (3 балів)"/>
                    <ComboBoxItem Content="Нормально (5 балів)"/>
                    <ComboBoxItem Content="Складно (10 балів)"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <Button Grid.Row="5" x:Name="AddToDraftBtn" Content="➕ Додати в чергу" 
                Height="30" Click="AddToDraftBtn_Click" Cursor="Hand" Margin="0,10,0,0"/>

        <StackPanel Grid.Row="6" Margin="0,15,0,15">
            <TextBlock x:Name="DraftCountLabel" Text="В черзі: 0 / 5" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,5"/>
            <ListBox x:Name="DraftListBox" VerticalAlignment="Stretch" MinHeight="100"/>
        </StackPanel>

        <Button Grid.Row="7" Content="✅ Зберегти всі в головний список" 
                Height="40" Background="#4CAF50" Foreground="White" 
                FontWeight="Bold" Click="SaveAllBtn_Click" Cursor="Hand"/>
    </Grid>
</Window>